<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane styleClass="root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controllers.HomeController">

    <!--NAV BAR-->
    <top>
        <HBox spacing="20" styleClass="nav-bar">
            <Label styleClass="nav-title" text="Interview Helper">
            <HBox.margin>
               <Insets top="10.0" />
            </HBox.margin></Label>
            <Pane HBox.hgrow="ALWAYS" />
            <Button style="-fx-font-size: 20px" styleClass="nav-button" text="Questions" />
            <Button onAction="#goToLogin" style="-fx-font-size: 20px" styleClass="nav-button" text="Sign In" />
        </HBox>
    </top>

    <!--Center Section-->
    <center>
        <HBox spacing="40" styleClass="hero-section">
            <VBox spacing="80" styleClass="hero-left">
            <VBox alignment="CENTER_LEFT" spacing="80">
               <Label style="-fx-text-fill: #000000" styleClass="heading-xl" text="Built to help you Ace Computer Science Interviews" wrapText="true">
                  <font>
                     <Font size="24.0" />
                  </font></Label>
               <Label prefHeight="67.0" prefWidth="392.0" style="-fx-font-weight: 600; -fx-font-size: 20px; -fx-text-fill: #000000" styleClass="text-muted" text="Level up your confidence with real questions that matter." wrapText="true">
                  <font>
                     <Font size="24.0" />
                  </font></Label>
            </VBox>
               <Pane VBox.vgrow="ALWAYS" />

               <HBox spacing="40">
                    <Button prefHeight="66.0" prefWidth="339.0" style="-fx-font-size: 30px" styleClass="button-primary" text="Browse Questions" />
                    <Button onAction="#goToLogin" prefHeight="66.0" prefWidth="194.0" style="-fx-font-size: 30px" styleClass="button-secondary" text="Sign In" />
               </HBox>
            </VBox>

            <!-- Right Side Image -->
            <ImageView fitHeight="673.0" fitWidth="1036.0" preserveRatio="true" style="-fx-translate-y: 100; -fx-translate-x: 40;">
                <image>
                    <Image url="@images/hero.png" />
                </image>
            <HBox.margin>
               <Insets bottom="30.0" />
            </HBox.margin>
            </ImageView>

        </HBox>
    </center>

    <stylesheets>
        <URL value="@styles.css" />
    </stylesheets>

</BorderPane>
